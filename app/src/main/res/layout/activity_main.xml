<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
                xmlns:tools="http://schemas.android.com/tools"
                android:id="@+id/container"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="10dp" >

    <RelativeLayout
            android:id="@+id/state"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true" >

        <TextView
                android:id="@+id/stateName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="40sp" />

        <TextView
                android:id="@+id/stateHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/stateName"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="@string/state_hint_stopped"
                android:textSize="18sp" />
    </RelativeLayout>

    <!--
         TODO Why can't I define textSize and textStyle
    	 in the timer container and have it inherited
    	 by the TextViews?
    -->

    <RelativeLayout
            android:id="@+id/timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/state"
            android:layout_centerHorizontal="true" >

        <TextView
                android:id="@+id/seconds"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/seconds"
                android:textSize="80sp"
                android:textStyle="bold" />

        <TextView
                android:id="@+id/timerLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/seconds"
                android:layout_centerHorizontal="true"
                android:text="@string/timer_label"
                android:textSize="16sp" />
    </RelativeLayout>

    <RelativeLayout
            android:id="@+id/buttons"
            android:layout_width="146dp"
            android:layout_height="74dp"
            android:layout_below="@id/timer"
            android:layout_centerHorizontal="true">

        <Button
                android:id="@+id/onAction"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:onClick="onPrimaryButton"
                android:text="@string/activate"/>

    </RelativeLayout>

</RelativeLayout>
